#include <iostream>
#include <string>
#include <iomanip>

using namespace std;

const int MAX = 10; 



string dodajOsobe(string *tabImion, string *tabNazwisk, bool *tabObecnosc, string *tabIndeks, string imie, string nazwisko) {
    for(int i = 0; i < MAX; i++) {
        if(tabNazwisk[i] == "") {
            
            tabImion[i] = imie;

            tabNazwisk[i] = nazwisko;

            tabObecnosc[i] = false;


            tabIndeks[i] = "---";

            return "Dodano: " + imie + " " + nazwisko;
        }
    }
    return "Blad: brak miejsca";
}


bool dodajObecnosc(string *tabNazwisk, bool *tabObecnosc, string nazwisko) {
    for(int i = 0; i < MAX; i++) {

        if(tabNazwisk[i] == nazwisko) {

            tabObecnosc[i] = !tabObecnosc[i];

            return true;
        }

    }
    return false;
}


void Pokaz(string *tabImion, string *tabNazwisk, bool *tabObecnosc, string *tabIndeks) {
    cout << "\n" << "INDEKS" << " | " << "IMIE" << " | " << "NAZWISKO" << " | STATUS" << endl;
    
    for(int i = 0; i < MAX; i++) {
        if(tabNazwisk[i] != "") {
            
            cout << tabIndeks[i] << " | " << tabImion[i] << " | " << tabNazwisk[i] << " | " 
                 << (tabObecnosc[i] ? "OBECNY" : "NIEOBECNY") << endl;
        }
    }
}


void usun(string *tabImion, string *tabNazwisk, bool *tabObecnosc, string *tabIndeks, string nazwisko) {
    for(int i = 0; i < MAX; i++) {
        if(tabNazwisk[i] == nazwisko) {
            for(int j = i; j < MAX - 1; j++) {
                
                
                tabImion[j] = tabImion[j + 1];
                tabNazwisk[j] = tabNazwisk[j + 1];
                tabObecnosc[j] = tabObecnosc[j + 1];
                tabIndeks[j] = tabIndeks[j + 1];
            }
            
            
            tabImion[MAX - 1] = "";
            tabNazwisk[MAX - 1] = "";
            tabObecnosc[MAX - 1] = false;
            tabIndeks[MAX - 1] = "---";
            
            cout << "Usunieto studenta." << endl;
            return;
        }
    }
}

void dodajIndeks(string *tabNazwisk, string *tabIndeks, string nazwisko, string indeks) {
    for(int i = 0; i < MAX; i++) {
        if(tabNazwisk[i] == nazwisko) {
            tabIndeks[i] = indeks;
            cout << "Nadano indeks." << endl;
            return;
        }
    }
}


string Edytuj(string *tabImion, string *tabNazwisk, string *tabIndeks, string nazwisko, string edycja, string nowe) {
    
     for(int i = 0; i < MAX; i++) {
        if(tabNazwisk[i] == nazwisko) {
            
            if(edycja == "imie") {
                tabImion[i] = nowe;
                return "Zmieniono imie";
            }
            
            else if(edycja == "nazwisko") {
                tabNazwisk[i] = nowe;
                
                return "Zmieniono nazwisko";
            }
            
            else if(edycja == "indeks") {
                tabIndeks[i] = nowe;
                return "Zmieniono indeks";
            }
            
        }
    }
    
    return "Blad: nie ma takiego studenta";
}



int main() {
    bool tabObecnosc[MAX];
    
    string tabImion[MAX];
    
    string tabNazwisk[MAX];
    
    string tabIndeks[MAX];
    
    
    string imie;
    
    string nazwisko ;
    string indeks;
    
    string edycja;
    
    
    string nowe;
    int temp = 0;

   
   
   
    for (int i = 0; i < MAX; i++) {
        tabImion[i] = "";
        tabNazwisk[i] = "";
        tabObecnosc[i] = false;
        tabIndeks[i] = "---";
    }
    
    
    do {
        cout << "\n1-Dodaj, 2-Obecnosc, 3-Pokaz, 4-Usun, 5-Indeks, 6-Edycja pola, 7-Wyjscie\nWybor: ";
        cin >> temp;

        switch(temp) {
            case 1:
                cout << "Imie: "; cin >> imie;
                cout << "Nazwisko: "; cin >> nazwisko;
                cout << dodajOsobe(tabImion, tabNazwisk, tabObecnosc, tabIndeks, imie, nazwisko) << endl;
                break;
                
            case 2:
                cout << "Nazwisko: "; cin >> nazwisko;
                if(!dodajObecnosc(tabNazwisk, tabObecnosc, nazwisko)) cout << "Nie znaleziono!";
                break;
                
            case 3:
                Pokaz(tabImion, tabNazwisk, tabObecnosc, tabIndeks);
                break;
                
            case 4:
                cout << "Kogo usunac?: "; cin >> nazwisko;
                usun(tabImion, tabNazwisk, tabObecnosc, tabIndeks, nazwisko);
                break;
                
            case 5:
                cout << "Nazwisko: "; cin >> nazwisko;
                cout << "Indeks: "; cin >> indeks;
                dodajIndeks(tabNazwisk, tabIndeks, nazwisko, indeks);
                break;
                
            case 6:
                cout << "Podaj nazwisko jakie chcialbys zmienic: ";
                cin >> nazwisko;
                
                cout << "Podaj imie/naziwsko/indeks ktory chcesz zmienic: ";
                cin >> edycja;
                
                cout << "Podaj nowa wartosc: ";
                cin >> nowe;
                
                cout << Edytuj(tabImion, tabNazwisk, tabIndeks, nazwisko, edycja, nowe) << endl;
                break;

            case 7:
                return 0;
        }
        
    } while(temp != 7);

    return 0;
}
